generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(cuid())

  firstName  String
  lastName   String

  email      String
  phone      String

  zipCode    String

  year       String
  make       String
  model      String

  createdAt  DateTime @default(now())
}